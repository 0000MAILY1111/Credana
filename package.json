{
  "name": "credsui",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend_credsui",
    "blockchain_credsui",
    "frontend_credsui"
  ],
  "scripts": {
    "dev": "npx concurrently \"npm run dev -w backend_credsui\" \"npm run dev -w frontend_credsui\"  \"npm run dev -w blockchain_credsui\" ",
